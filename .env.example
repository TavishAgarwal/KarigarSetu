# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret

# ─── Google Gemini AI (Direct API — fallback when Vertex AI not configured) ──
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ─── Google Cloud Platform ────────────────────────────────────────────────────
# Option 1 (recommended): JSON blob of your service account key
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option 2: Individual credentials
# GCP_PROJECT_ID=your_gcp_project_id
# GCP_CLIENT_EMAIL=your_service_account_email
# GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Option 3: Application Default Credentials file path (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCP region / location (default: us-central1)
GOOGLE_LOCATION=us-central1
GOOGLE_PROJECT_ID=your_gcp_project_id

# ─── Google Cloud Storage ─────────────────────────────────────────────────────
GCS_BUCKET_NAME=your_bucket_name

# ─── Firebase (Client-side) ──────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Firebase Admin (Server-side) ────────────────────────────────────────────
# Option 1 (recommended): JSON blob of your Firebase Admin SDK service account
# FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option 2: Individual credentials
# FIREBASE_ADMIN_PROJECT_ID=your_firebase_project_id
# FIREBASE_ADMIN_CLIENT_EMAIL=your_firebase_admin_email
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── BigQuery ─────────────────────────────────────────────────────────────────
BIGQUERY_DATASET=karigarsetu_analytics

# ─── Google Translate API ─────────────────────────────────────────────────────
# GOOGLE_TRANSLATE_API_KEY=your_translate_api_key

# ─── Google Maps ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Speech-to-Text ──────────────────────────────────────────────────────────
# Uses GCP credentials above — no additional config needed

# ─── Cloud Functions ──────────────────────────────────────────────────────────
# Primary names (recommended):
AI_LISTING_FUNCTION_URL=https://region-project.cloudfunctions.net/productPipeline
ORDER_NOTIFY_FUNCTION_URL=https://region-project.cloudfunctions.net/orderNotification
# Alternative names (also supported):
# CLOUD_FUNCTION_PRODUCT_PIPELINE_URL=https://region-project.cloudfunctions.net/productPipeline
# CLOUD_FUNCTION_ORDER_NOTIFICATION_URL=https://region-project.cloudfunctions.net/orderNotification
CLOUD_FUNCTION_WEBHOOK_SECRET=your_webhook_secret

# ─── Cloudinary (Optional — legacy fallback) ─────────────────────────────────
# Get your credentials from: https://console.cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
